# Environment Template for AI-CHD-CDSS
ENV=development
DEBUG=true
PROJECT_NAME="AI-CHD-CDSS"

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=chd_cdss
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# Security
JWT_SECRET_KEY=generate_a_very_secure_random_key_here_for_prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Path to raw MIMIC-IV demo database
MIMIC_DATA_PATH=/app/data/mimic
PROCESSED_DATA_PATH=/app/data/processed_chd_data.csv

# CORS Origins
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1
